[Unit]
Description=Fixy daily digest (lee leads + healthcheck, manda Telegram)
After=network.target fixy-backend.service
Wants=fixy-backend.service

[Service]
Type=oneshot
User=fixy
Group=fixy
EnvironmentFile=/etc/fixy-agents.env
ExecStart=/opt/fixy-agents/daily-digest.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
StandardOutput=append:/var/log/fixy-agents.log
StandardError=append:/var/log/fixy-agents.log
